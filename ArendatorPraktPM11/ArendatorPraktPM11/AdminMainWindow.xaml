<Window x:Class="ArendatorPraktPm11.AdminMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1a237e" Offset="0"/>
            <GradientStop Color="#0d47a1" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#f44336"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#d32f2f"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReportButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#ff9800"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#fb8c00"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e3f2fd"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <TextBlock Text="⚙️ Панель администратора" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="lblAdminName" FontSize="16" Foreground="#ffeb3b" Margin="20,0,0,0"/>
                </StackPanel>
                <!-- Кнопка выхода справа -->
                <Button Content="🚪 Выйти" Click="btnLogout_Click" 
                        Style="{StaticResource ExitButton}"
                        VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковое меню (ВСЕ ТАБЛИЦЫ) -->
            <Border Grid.Column="0" Background="#f5f5f5" CornerRadius="10" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="lstTables" SelectionChanged="lstTables_SelectionChanged"
                             BorderThickness="0" Background="Transparent" Margin="10">
                        <ListBoxItem Content="📋 Договоры" Tag="contracts" Style="{StaticResource ListBoxItemStyle}"/>
                        <ListBoxItem Content="🏠 Объекты" Tag="objects" Style="{StaticResource ListBoxItemStyle}"/>
                        <ListBoxItem Content="👥 Сотрудники" Tag="employees" Style="{StaticResource ListBoxItemStyle}"/>
                        <ListBoxItem Content="🏢 Арендаторы" Tag="tenants" Style="{StaticResource ListBoxItemStyle}"/>
                        <ListBoxItem Content="💰 Платежи" Tag="payments" Style="{StaticResource ListBoxItemStyle}"/>
                        <ListBoxItem Content="👤 Пользователи" Tag="users" Style="{StaticResource ListBoxItemStyle}"/>
                        <ListBoxItem Content="📌 Должности" Tag="positions" Style="{StaticResource ListBoxItemStyle}"/>
                        <ListBoxItem Content="🏛️ Отделы" Tag="departments" Style="{StaticResource ListBoxItemStyle}"/>
                        <ListBoxItem Content="📜 Журнал аудита" Tag="audit_log" Style="{StaticResource ListBoxItemStyle}"/>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <!-- Область с данными -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="lblTitle" Text="Выберите раздел" FontSize="18" 
                               FontWeight="Bold" Foreground="#1a237e" Margin="0,0,0,15"/>

                    <!-- Кнопки действий -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="➕ Добавить" Click="btnAdd_Click" Background="#4CAF50" Style="{StaticResource ActionButton}"/>
                        <Button Content="✏️ Редактировать" Click="btnEdit_Click" Background="#2196F3" Style="{StaticResource ActionButton}"/>
                        <Button Content="🗑️ Удалить" Click="btnDelete_Click" Background="#f44336" Style="{StaticResource ActionButton}"/>
                        <Button Content="🔄 Обновить" Click="btnRefresh_Click" Background="#607d8b" Style="{StaticResource ActionButton}"/>
                        <Button Content="📊 Отчёт" Click="btnReport_Click" Background="#ff9800" Style="{StaticResource ReportButton}"/>
                    </StackPanel>

                    <!-- Таблица данных -->
                    <DataGrid x:Name="dgData" Grid.Row="2" AutoGenerateColumns="True" 
                              SelectionMode="Single" CanUserAddRows="False"
                              FontSize="13" AlternatingRowBackground="#f9f9f9" RowHeight="35"
                              IsReadOnly="True"/>

                    <!-- Строка статуса -->
                    <TextBlock x:Name="lblStatus" Grid.Row="3" Text="Готово" 
                               Margin="0,10,0,0" FontSize="12" Foreground="Gray"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>