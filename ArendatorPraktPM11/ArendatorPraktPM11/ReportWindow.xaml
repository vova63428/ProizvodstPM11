<Window x:Class="ArendatorPraktPm11.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёт" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="lblTitle" Text="Отчёт" FontSize="18" FontWeight="Bold" 
                   Foreground="#1a237e" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <DataGrid x:Name="dgReport" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" FontSize="13" AlternatingRowBackground="#f9f9f9"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="📊 В Excel" Click="btnExportToExcel_Click" Width="110" Height="35" 
                    Margin="0,0,10,0" Background="#4CAF50" Foreground="White"/>
            <Button Content="📋 Копировать" Click="btnCopy_Click" Width="110" Height="35" 
                    Margin="0,0,10,0" Background="#607d8b" Foreground="White"/>
            <Button Content="❌ Закрыть" Click="btnClose_Click" Width="110" Height="35" 
                    Background="#f44336" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>