<Window x:Class="ArendatorPraktPm11.EmployeeMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель сотрудника" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1a237e" Offset="0"/>
            <GradientStop Color="#0d47a1" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,8"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e3f2fd"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReportButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#ff9800"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#fb8c00"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}">
            <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                <TextBlock Text="👔 Панель сотрудника" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="lblEmployeeName" FontSize="16" Foreground="#ffeb3b" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковое меню -->
            <Border Grid.Column="0" Background="#f5f5f5" CornerRadius="10" Margin="0,0,10,0">
                <ListBox x:Name="lstTables" SelectionChanged="lstTables_SelectionChanged"
                         BorderThickness="0" Background="Transparent" Margin="10">
                    <ListBoxItem Content="📋 Договоры" Tag="contracts" Style="{StaticResource ListBoxItemStyle}"/>
                    <ListBoxItem Content="🏠 Объекты" Tag="objects" Style="{StaticResource ListBoxItemStyle}"/>
                    <ListBoxItem Content="🏢 Арендаторы" Tag="tenants" Style="{StaticResource ListBoxItemStyle}"/>
                    <ListBoxItem Content="💰 Платежи" Tag="payments" Style="{StaticResource ListBoxItemStyle}"/>
                </ListBox>
            </Border>

            <!-- Область с данными -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="lblTitle" Text="Выберите раздел" FontSize="16" 
                               FontWeight="Bold" Foreground="#1a237e" Margin="0,0,0,10"/>

                    <!-- Кнопка отчёта -->
                    <Button Grid.Row="1" Content="📊 Отчёт" Click="btnReport_Click" 
                            Style="{StaticResource ReportButton}" Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgData" Grid.Row="2" AutoGenerateColumns="True" 
                              IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                              FontSize="13" AlternatingRowBackground="#f9f9f9" RowHeight="35"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>