<Window x:Class="ArendatorPraktPm11.TenantMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Личный кабинет арендатора" Height="550" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1a237e" Offset="0"/>
            <GradientStop Color="#0d47a1" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ExitButton" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#f44336"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#d32f2f"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="#f5f5f5"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <TextBlock Text="🏢 Личный кабинет" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text=" | " FontSize="20" Foreground="White"/>
                    <TextBlock x:Name="lblTenantName" FontSize="18" Foreground="#ffeb3b"/>
                </StackPanel>
                <!-- Кнопка выхода справа -->
                <Button Content="🚪 Выйти" Click="btnLogout_Click" 
                        Style="{StaticResource ExitButton}"
                        VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="15" TabStripPlacement="Top">
            <TabItem Header="📄 Мои договоры" Style="{StaticResource TabItemStyle}">
                <DataGrid x:Name="dgContracts" AutoGenerateColumns="True" IsReadOnly="True" 
                          CanUserAddRows="False" FontSize="13" 
                          AlternatingRowBackground="#f9f9f9" RowHeight="35"/>
            </TabItem>

            <TabItem Header="💰 История платежей" Style="{StaticResource TabItemStyle}">
                <DataGrid x:Name="dgPayments" AutoGenerateColumns="True" IsReadOnly="True" 
                          CanUserAddRows="False" FontSize="13"
                          AlternatingRowBackground="#f9f9f9" RowHeight="35"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>