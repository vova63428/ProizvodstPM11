<Window x:Class="ArendatorPraktPm11.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление / Редактирование" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="lblTitle" FontSize="18" FontWeight="Bold" 
                   Foreground="#1a237e" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="spFields"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35" 
                    Margin="0,0,10,0" Background="#4CAF50" Foreground="White"
                    Click="btnSave_Click" Cursor="Hand"/>
            <Button Content="Отмена" Width="100" Height="35" Click="btnCancel_Click" 
                    Background="#f44336" Foreground="White" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>